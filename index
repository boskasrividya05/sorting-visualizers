
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SortLab — Candle Visualizer</title>
  <link rel="stylesheet" href="style.css"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
</head>
<body class="algo-bubble">

  <!-- ══ HEADER ══════════════════════════════════════════ -->
  <header class="header">
    <div class="header-inner">
      <div class="logo">
        <div class="logo-bars">
          <span class="lb lb1"></span><span class="lb lb2"></span>
          <span class="lb lb3"></span><span class="lb lb4"></span>
        </div>
        <span class="logo-text">Sort<b>Lab</b></span>
      </div>

      <div class="main-tabs">
        <button class="main-tab active" data-mode="separate">🕯 Individual</button>
        <button class="main-tab"        data-mode="together">⚡ All Together</button>
      </div>

      <div class="header-right">
        <span class="algo-theme-badge" id="themeBadge">● Bubble Sort</span>
        <span class="header-hint">Space=Play · ←→=Step · G=New · 1/2=Mode</span>
      </div>
    </div>
  </header>

  <!-- ══ PAGE 1 : INDIVIDUAL ════════════════════════════ -->
  <div class="page active" id="pageIndividual">
    <div class="main">

      <aside class="sidebar">

        <div class="card">
          <div class="card-title">Algorithm</div>
          <div class="algo-list" id="algoButtons">
            <button class="algo-btn active" data-algo="bubble">
              <span class="algo-ico">◎</span>
              <span class="algo-txt"><span class="algo-name">Bubble Sort</span><span class="algo-big-o">O(n²)</span></span>
            </button>
            <button class="algo-btn" data-algo="selection">
              <span class="algo-ico">◈</span>
              <span class="algo-txt"><span class="algo-name">Selection Sort</span><span class="algo-big-o">O(n²)</span></span>
            </button>
            <button class="algo-btn" data-algo="insertion">
              <span class="algo-ico">▶</span>
              <span class="algo-txt"><span class="algo-name">Insertion Sort</span><span class="algo-big-o">O(n²)</span></span>
            </button>
            <button class="algo-btn" data-algo="merge">
              <span class="algo-ico">⊞</span>
              <span class="algo-txt"><span class="algo-name">Merge Sort</span><span class="algo-big-o">O(n log n)</span></span>
            </button>
            <button class="algo-btn" data-algo="quick">
              <span class="algo-ico">⚡</span>
              <span class="algo-txt"><span class="algo-name">Quick Sort</span><span class="algo-big-o">O(n log n)</span></span>
            </button>
          </div>
        </div>

        <!-- Auto-chain -->
        <div class="card chain-card">
          <div class="card-title">Auto Chain Mode</div>
          <div class="chain-row">
            <label class="toggle-switch">
              <input type="checkbox" id="chainToggle"/>
              <span class="toggle-track"><span class="toggle-thumb"></span></span>
            </label>
            <span class="chain-label" id="chainLabel">OFF</span>
          </div>
          <div class="chain-hint">Auto-runs all 5 algorithms one after another.</div>
          <div class="chain-progress" id="chainProgress" style="display:none">
            <span class="cp-item" data-algo="bubble">Bubble</span>
            <span class="cp-sep">→</span>
            <span class="cp-item" data-algo="selection">Select</span>
            <span class="cp-sep">→</span>
            <span class="cp-item" data-algo="insertion">Insert</span>
            <span class="cp-sep">→</span>
            <span class="cp-item" data-algo="merge">Merge</span>
            <span class="cp-sep">→</span>
            <span class="cp-item" data-algo="quick">Quick</span>
          </div>
        </div>

        <div class="card">
          <div class="card-title">Complexity</div>
          <div class="cx-list">
            <div class="cx-row"><span class="cx-label cx-best">Best</span><span class="cx-val" id="cBest">O(n)</span></div>
            <div class="cx-row"><span class="cx-label cx-avg">Average</span><span class="cx-val" id="cAvg">O(n²)</span></div>
            <div class="cx-row"><span class="cx-label cx-worst">Worst</span><span class="cx-val" id="cWorst">O(n²)</span></div>
            <div class="cx-row"><span class="cx-label cx-space">Space</span><span class="cx-val" id="cSpace">O(1)</span></div>
          </div>
        </div>

        <div class="card">
          <div class="card-title">Live Stats</div>
          <div class="stat-grid">
            <div class="stat-box"><div class="stat-num" id="statComp">0</div><div class="stat-lbl">Comparisons</div></div>
            <div class="stat-box"><div class="stat-num" id="statSwap">0</div><div class="stat-lbl">Swaps</div></div>
          </div>
          <div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>
          <div class="step-label" id="statStep">Step 0 / 0</div>
        </div>

        <div class="card">
          <div class="card-title">Legend</div>
          <div class="legend-list">
            <div class="leg-item"><span class="dot dot-def"></span><div><b>Normal</b> — full flame, unsorted candle</div></div>
            <div class="leg-item"><span class="dot dot-cmp"></span><div><b>Comparing</b> — bright yellow blaze</div></div>
            <div class="leg-item"><span class="dot dot-swp"></span><div><b>Swapping</b> — red plasma burst</div></div>
            <div class="leg-item"><span class="dot dot-srt"></span><div><b>Sorted</b> — melted down, green glow, fixed</div></div>
            <div class="leg-item"><span class="dot dot-pvt"></span><div><b>Pivot</b> — crimson torch</div></div>
          </div>
        </div>

      </aside>

      <section class="viz-panel">
        <div class="viz-topbar">
          <div class="running-badge">
            <span class="rb-ring" id="rbRing"></span>
            <span class="rb-name" id="badgeName">Bubble Sort</span>
          </div>
          <div class="controls-row">
            <div class="ctrl-group">
              <label class="ctrl-lbl">Candles <em id="sizeVal">22</em></label>
              <input type="range" id="arraySize" min="5" max="48" value="22"/>
            </div>
            <div class="ctrl-group">
              <label class="ctrl-lbl">Speed <em id="speedVal">5</em></label>
              <input type="range" id="speedSlider" min="1" max="10" value="5"/>
            </div>
          </div>
        </div>

        <!-- Candle chart: canvas bg + bars on top -->
        <div class="bars-wrap">
          <canvas id="bgCanvas"></canvas>
          <div class="bars-area" id="barContainer"></div>
        </div>

        <div class="transition-flash" id="transFlash"></div>

        <div class="status-strip" id="statusStrip">
          <span class="status-icon">●</span>
          <span id="statusText">Generate candles and press Start Sorting.</span>
        </div>

        <div class="transport">
          <button class="btn btn-ghost" id="btnGenerate">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.45"/></svg>
            New Array
          </button>
          <button class="btn btn-ghost" id="btnPrev" disabled>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polygon points="19 20 9 12 19 4 19 20"/><line x1="5" y1="19" x2="5" y2="5"/></svg>
            Prev
          </button>
          <button class="btn btn-primary" id="btnStart">
            <svg class="play-icon" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            <span id="btnStartLabel">Start Sorting</span>
          </button>
          <button class="btn btn-ghost" id="btnNext" disabled>
            Next
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" y1="5" x2="19" y2="19"/></svg>
          </button>
          <button class="btn btn-reset" id="btnReset">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
            Reset
          </button>
        </div>
      </section>
    </div>
  </div>

  <!-- ══ PAGE 2 : ALL TOGETHER ══════════════════════════ -->
  <div class="page" id="pageAll">
    <div class="all-header">
      <div class="all-controls">
        <button class="btn btn-ghost" id="btnAllGenerate">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.45"/></svg>
          New Array
        </button>
        <button class="btn btn-primary" id="btnAllStart">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <span id="btnAllLabel">Run All 5</span>
        </button>
        <button class="btn btn-reset" id="btnAllReset">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
          Reset
        </button>
        <div class="ctrl-group" style="min-width:130px">
          <label class="ctrl-lbl">Speed <em id="allSpeedVal">5</em></label>
          <input type="range" id="allSpeedSlider" min="1" max="10" value="5"/>
        </div>
        <div class="ctrl-group" style="min-width:130px">
          <label class="ctrl-lbl">Candles <em id="allSizeVal">18</em></label>
          <input type="range" id="allSizeSlider" min="5" max="36" value="18"/>
        </div>
      </div>
      <div class="all-status" id="allStatus">● Press Run All 5 to sort simultaneously.</div>
    </div>
    <div class="all-grid" id="allGrid"></div>
  </div>

  <script src="script.js"></script>
</body>
</html>
